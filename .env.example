# Copy to .env.local and paste your real key. Never commit .env.local.
# Server-only: read exclusively inside the /api/parse route, never exposed to the browser.

# Active provider: OpenRouter (OpenAI-compatible). Direct Anthropic billing failed for a UA card.
OPENROUTER_API_KEY=

# Optional: override the OpenRouter model slug (defaults to anthropic/claude-haiku-4.5).
# OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Only needed if you flip src/lib/parse/provider.ts back to ACTIVE_PROVIDER = "anthropic".
# ANTHROPIC_API_KEY=
